{
  "name": "webapp",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "yarn workspace @scope/data prisma generate",
    "db:push": "yarn workspace @scope/data prisma db push",
    "db:migrate": "yarn workspace @scope/data prisma migrate dev"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "yarn@1.22.22"
}
